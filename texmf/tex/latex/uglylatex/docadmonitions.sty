% We use \relax in the false branch of \ifdefstring to ensure that LaTeX  
% does not encounter a missing argument error. The \ifdefstring macro  
% requires four parameters: (1) the tested string, (2) the target string, 
% (3) the code to execute if the strings match, and (4) the code to 
% execute if they do not match. If the false branch is omitted, LaTeX will
% fail with an error such as:  
%  
%     ! LaTeX Error: Missing \begin{document}.  
%  
% This happens because \ifdefstring expects an explicit false branch, even
% if no action is required. Using \relax ensures LaTeX has a valid 
% fallback without introducing an empty group ({}) that might affect
% parsing.  

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Define tcolorbox format.

\tcbuselibrary{skins, breakable}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Define a default tcolorbox set.

\tcbset{
  uglylatexdefault/.style={
    enhanced,
    frame hidden,
    breakable,
    fonttitle=\bfseries\normalsize, % Bold for the font title
    attach title to upper,
    after title={\par},
    boxed title style={
      enhanced,
      boxrule=0pt,
      colback=white!0!white,
      sharp corners,
      left=0pt, right=0pt, top=0pt, bottom=0pt,
      boxsep=0pt,
      arc=0mm, outer arc=0mm,
    },
    fontupper=\normalsize,
    colback=white!0!white,
    colbacktitle=white!0!white,
    boxrule=0pt,
    % Hide the default tcolorbox frame completely. Using leftrule/toprule/
    % bottomrule/rightrule alone can leave very thin residual lines from the
    % box skin. We will draw the left border explicitly with borderline west.
    toprule=0pt,
    bottomrule=0pt,
    rightrule=0pt,
    arc=0mm, outer arc=0mm,
    left=5pt, right=2.5pt,  % Paddings.
    top=2.5pt, bottom=2.5pt
  }
}


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Define tcolorboxes for info, warning, tips, important and caution.
%
% Note that its `info' not `note' here (Although GitHub support `note' 
% block instead of `info', on most other platforms such as Obsidian, the 
% `info' block is more common.)
%
% Use explicit left borderlines instead of relying on leftrule/toprule/
% bottomrule/rightrule alone. The default tcolorbox skin can still draw
% very thin residual frame lines, so we hide the frame and draw a single
% west borderline for each box.

\newtcolorbox{info}[1][infotypecolor]{%
  uglylatexdefault,
  colframe=#1,
  coltitle=#1,
  % Explicit left border only. This is preferred over leftrule because
  % leftrule can leave hairline remnants on other box edges.
  borderline west={0.5mm}{0pt}{#1},
  title={\infotypename~\thetcbcounter}
}

\newtcolorbox{warning}[1][warningtypecolor]{%
  uglylatexdefault,
  colframe=#1,
  coltitle=#1,
  borderline west={0.5mm}{0pt}{#1},
  title={\warningtypename~\thetcbcounter}
}

\newtcolorbox{tip}[1][tiptypecolor]{%
  uglylatexdefault,
  colframe=#1,
  coltitle=#1,
  borderline west={0.5mm}{0pt}{#1},
  title={\tiptypename~\thetcbcounter}
}

\newtcolorbox{important}[1][importanttypecolor]{%
  uglylatexdefault,
  colframe=#1,
  coltitle=#1,
  borderline west={0.5mm}{0pt}{#1},
  title={\importanttypename~\thetcbcounter}
}

\newtcolorbox{caution}[1][cautiontypecolor]{%
  uglylatexdefault,
  colframe=#1,
  coltitle=#1,
  borderline west={0.5mm}{0pt}{#1},
  title={\cautiontypename~\thetcbcounter}
}
